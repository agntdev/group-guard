[
  {
    "name": "/logs shows no logs when empty",
    "steps": [
      {
        "send": { "text": "/logs" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📜 No moderation logs yet."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "admin:logs button shows no logs",
    "steps": [
      {
        "send": { "callback": "admin:logs" },
        "expect": [
          {
            "method": "answerCallbackQuery"
          },
          {
            "method": "editMessageText",
            "payload": {
              "text": "📜 No moderation logs yet."
            }
          }
        ]
      }
    ]
  }
]
