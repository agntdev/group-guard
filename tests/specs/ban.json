[
  {
    "name": "/ban with user and reason",
    "steps": [
      {
        "send": { "text": "/ban @spammer 7d spamming" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "🚫 @spammer has been banned.\n7d spamming"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/ban without args shows usage",
    "steps": [
      {
        "send": { "text": "/ban" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Usage: /ban @username [duration/reason]"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/ban with user only",
    "steps": [
      {
        "send": { "text": "/ban @spammer" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "🚫 @spammer has been banned."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "admin:ban button shows instructions",
    "steps": [
      {
        "send": { "callback": "admin:ban" },
        "expect": [
          {
            "method": "answerCallbackQuery"
          },
          {
            "method": "editMessageText",
            "payload": {
              "text": "To ban a user, type:\n/ban @username [duration/reason]\n\nExamples:\n/ban @spammer\n/ban @troll 7d spamming"
            }
          }
        ]
      }
    ]
  }
]
