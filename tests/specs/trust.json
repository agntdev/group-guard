[
  {
    "name": "/trust add with user",
    "steps": [
      {
        "send": { "text": "/trust add @trusted_user" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "🛡️ @trusted_user has been added to the trust list."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/trust remove with user",
    "steps": [
      {
        "send": { "text": "/trust remove @trusted_user" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "🛡️ @trusted_user has been removed from the trust list."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/trust without args shows usage",
    "steps": [
      {
        "send": { "text": "/trust" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Usage: /trust add|remove @username [reason]"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "admin:trust button shows trust list info",
    "steps": [
      {
        "send": { "callback": "admin:trust" },
        "expect": [
          {
            "method": "answerCallbackQuery"
          },
          {
            "method": "editMessageText",
            "payload": {
              "text": "🛡️ Trust list management\n\nCommands:\n/trust add @username [reason]\n/trust remove @username\n\nNo trusted users yet."
            }
          }
        ]
      }
    ]
  }
]
