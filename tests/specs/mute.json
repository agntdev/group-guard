[
  {
    "name": "/mute with user and duration",
    "steps": [
      {
        "send": { "text": "/mute @spammer 1h" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "🔇 @spammer has been muted for 1h."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/mute without args shows usage",
    "steps": [
      {
        "send": { "text": "/mute" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Usage: /mute @username [duration]"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/mute with user only",
    "steps": [
      {
        "send": { "text": "/mute @troll" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "🔇 @troll has been muted for indefinite."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "admin:mute button shows instructions",
    "steps": [
      {
        "send": { "callback": "admin:mute" },
        "expect": [
          {
            "method": "answerCallbackQuery"
          },
          {
            "method": "editMessageText",
            "payload": {
              "text": "To mute a user, type:\n/mute @username [duration]\n\nExamples:\n/mute @spammer 1h\n/mute @troll 24h"
            }
          }
        ]
      }
    ]
  }
]
