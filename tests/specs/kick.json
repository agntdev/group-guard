[
  {
    "name": "/kick with user and reason",
    "steps": [
      {
        "send": { "text": "/kick @spammer spamming" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "👢 @spammer has been kicked.\nReason: spamming"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/kick without args shows usage",
    "steps": [
      {
        "send": { "text": "/kick" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Usage: /kick @username [reason]"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/kick with user only",
    "steps": [
      {
        "send": { "text": "/kick @troll" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "👢 @troll has been kicked."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "admin:kick button shows instructions",
    "steps": [
      {
        "send": { "callback": "admin:kick" },
        "expect": [
          {
            "method": "answerCallbackQuery"
          },
          {
            "method": "editMessageText",
            "payload": {
              "text": "To kick a user, type:\n/kick @username [reason]\n\nThis removes the user from the group."
            }
          }
        ]
      }
    ]
  }
]
