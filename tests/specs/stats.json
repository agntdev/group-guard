[
  {
    "name": "/stats shows no data when empty",
    "steps": [
      {
        "send": { "text": "/stats" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📈 No statistics available yet."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "admin:stats button shows no data",
    "steps": [
      {
        "send": { "callback": "admin:stats" },
        "expect": [
          {
            "method": "answerCallbackQuery"
          },
          {
            "method": "editMessageText",
            "payload": {
              "text": "📈 No statistics available yet."
            }
          }
        ]
      }
    ]
  }
]
